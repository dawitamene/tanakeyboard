<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AddiyonKeyboard" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color (Addiyon palette). -->
        <item name="colorPrimary">@color/addiyon_vermillion</item>
        <item name="colorPrimaryVariant">@color/addiyon_charcoal</item>
        <item name="colorOnPrimary">@color/addiyon_ink</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/addiyon_vermillion_dark</item>
        <item name="colorSecondaryVariant">@color/addiyon_vermillion_dark</item>
        <item name="colorOnSecondary">@color/addiyon_ink</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
</resources>