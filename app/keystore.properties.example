# Copy this file to `keystore.properties` (same folder) and fill in real values.
# `keystore.properties` is gitignored -- NEVER commit it or the .jks itself.
#
# Create the upload keystore once:
#   keytool -genkey -v -keystore tana-upload.jks \
#           -alias tana -keyalg RSA -keysize 2048 -validity 10000
# Then back up tana-upload.jks + these passwords somewhere permanent -- losing
# them means you can't ship updates (unless enrolled in Play App Signing).

storeFile=tana-upload.jks
storePassword=CHANGE_ME
keyAlias=tana
keyPassword=CHANGE_ME
